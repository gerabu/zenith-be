# --- Application ---
PORT=3000

# --- Database (PostgreSQL) ---
# These feed both docker-compose and the DATABASE_URL below.
POSTGRES_USER=zenith
POSTGRES_PASSWORD=zenith
POSTGRES_DB=zenith
POSTGRES_PORT=5432

# Prisma connection string. Must match the POSTGRES_* values above.
DATABASE_URL="postgresql://zenith:zenith@localhost:5432/zenith?schema=public"

# --- Google authentication ---
# OAuth 2.0 Client ID from Google Cloud Console. The backend validates that
# incoming ID tokens were issued for this audience.
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"

# Google issuer + JWKS endpoint used to cryptographically verify ID tokens.
# Defaults below are the standard Google values; override only if needed.
GOOGLE_ISSUER="https://accounts.google.com"
GOOGLE_JWKS_URI="https://www.googleapis.com/oauth2/v3/certs"
